# Environment Variables Example
# Copy this file to .env.local and fill in your values

# ============================================
# GENERAL
# ============================================

# The base URL of your application (for absolute URLs in emails, etc.)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# OPTIONAL: AUTHENTICATION (if using NextAuth)
# ============================================

# NextAuth.js Configuration
# Uncomment and configure if you add authentication
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# ============================================
# OPTIONAL: EMAIL (if using contact form with backend)
# ============================================

# Email service credentials (e.g., SendGrid, Resend, Nodemailer)
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_SERVER_HOST=smtp.example.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=your-email@example.com
# EMAIL_SERVER_PASSWORD=your-password

# OR use a service like Resend
# RESEND_API_KEY=re_xxxxxxxxxxxx

# ============================================
# OPTIONAL: ANALYTICS
# ============================================

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics (automatically enabled on Vercel)
# No configuration needed

# ============================================
# OPTIONAL: THIRD-PARTY APIS
# ============================================

# If you integrate any APIs, add them here
# NEXT_PUBLIC_SOME_API_KEY=your-api-key
